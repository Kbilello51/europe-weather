"""
European Weather Database — One-Click Updater
==============================================
Pulls ERA5 historical data + latest ECMWF forecast for all ENTSO-E bidding
zones, population-weighted to match gas/power demand footprints.

Data source : Open-Meteo (free, no API key)
  Historical : ERA5 reanalysis  →  archive-api.open-meteo.com  (back to 1940)
  Forecast   : ECMWF IFS        →  api.open-meteo.com          (16 days ahead)

Output (./data/):
  historical/<ZONE>.csv   ERA5 archive, appended incrementally each run
  forecast/<ZONE>.csv     Latest model run, overwritten each run
  combined/<ZONE>.csv     Historical + forecast merged (history takes priority)
  europe_all_zones.csv    All zones + all dates in one flat file

Usage examples
--------------
  First run (downloads full history):
    python update_europe_weather.py

  Daily update (incremental, ~30 s):
    python update_europe_weather.py

  Specific zones only:
    python update_europe_weather.py --zones DE FR NL BE

  Longer history:
    python update_europe_weather.py --start-date 1980-01-01

  Force full re-download:
    python update_europe_weather.py --force-reload

  List available zones:
    python update_europe_weather.py --list-zones
"""

import argparse
import logging
import sys
from datetime import date, timedelta
from pathlib import Path

import numpy as np
import pandas as pd
from tqdm import tqdm

from config import ZONES, ALL_ZONES, DEFAULT_HISTORICAL_START, ZONE_GROUPS
import weather_api
from weather_api import fetch_historical_chunk, fetch_forecast, year_chunks, inter_call_sleep, using_commercial
from weather_processor import aggregate_zone

# ─── logging ──────────────────────────────────────────────────────────────────
logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s  %(levelname)-7s  %(message)s",
    datefmt="%H:%M:%S",
)
log = logging.getLogger(__name__)

# ─── canonical column order for all output CSVs ───────────────────────────────
COLUMNS = [
    "date", "zone", "zone_name", "data_type",
    "temp_max_c", "temp_min_c", "temp_mean_c",
    "hdd_15c", "cdd_15c", "hdd_18c", "cdd_18c",
    "precipitation_mm", "cloud_cover_pct",
    "solar_radiation_mj_m2",
    "wind_speed_max_kmh", "wind_direction_deg",
    "stations_used",
]

# ERA5 has ~5-day processing lag; pull historical up to 8 days ago,
# then let forecast's past_days=7 overlap to cover the gap.
ARCHIVE_LAG_DAYS = 8


# ─── helpers ──────────────────────────────────────────────────────────────────

def ensure_dirs(data_dir: Path) -> None:
    for sub in ("historical", "forecast", "combined"):
        (data_dir / sub).mkdir(parents=True, exist_ok=True)


def load_csv(path: Path) -> pd.DataFrame:
    if path.exists() and path.stat().st_size > 0:
        return pd.read_csv(path, parse_dates=["date"])
    return pd.DataFrame(columns=COLUMNS)


def last_date(df: pd.DataFrame) -> date | None:
    if df.empty or "date" not in df.columns:
        return None
    return df["date"].max().date()


def stamp(df: pd.DataFrame, zone_key: str, data_type: str) -> pd.DataFrame:
    """Add zone / zone_name / data_type columns and reorder to canonical layout."""
    df = df.copy()
    df["zone"]      = zone_key
    df["zone_name"] = ZONES[zone_key]["name"]
    df["data_type"] = data_type
    # Ensure all columns exist (fill missing with NaN)
    for col in COLUMNS:
        if col not in df.columns:
            df[col] = np.nan
    return df[COLUMNS]


# ─── per-zone update ──────────────────────────────────────────────────────────

def update_zone(
    zone_key: str,
    data_dir: Path,
    start_date: str,
    force_reload: bool,
) -> dict:
    """
    Incrementally update historical + fetch fresh forecast for one zone.
    Returns a summary dict for the progress table.
    """
    zone_cfg  = ZONES[zone_key]
    stations  = zone_cfg["stations"]

    hist_path = data_dir / "historical" / f"{zone_key}.csv"
    fcst_path = data_dir / "forecast"   / f"{zone_key}.csv"
    comb_path = data_dir / "combined"   / f"{zone_key}.csv"

    # ── 1. Historical (ERA5 archive) ──────────────────────────────────────────
    existing_hist = pd.DataFrame(columns=COLUMNS) if force_reload else load_csv(hist_path)
    last_hist_dt  = last_date(existing_hist)

    hist_end   = (date.today() - timedelta(days=ARCHIVE_LAG_DAYS)).isoformat()
    hist_start = start_date if (force_reload or last_hist_dt is None) else (
        last_hist_dt + timedelta(days=1)
    ).isoformat()

    new_hist_rows = 0
    combined_hist = existing_hist.copy() if not existing_hist.empty else pd.DataFrame(columns=COLUMNS)

    if hist_start <= hist_end:
        chunks = year_chunks(hist_start, hist_end)
        log.info("[%s]  archive  %s → %s  (%d year-chunks)",
                 zone_key, hist_start, hist_end, len(chunks))

        for chunk_idx, (cs, ce) in enumerate(chunks):
            log.info("[%s]  fetching %s → %s  (%d/%d)",
                     zone_key, cs, ce, chunk_idx + 1, len(chunks))
            raw_chunk = fetch_historical_chunk(stations, cs, ce)
            chunk_df  = aggregate_zone(raw_chunk, stations)

            if not chunk_df.empty:
                chunk_df = stamp(chunk_df, zone_key, "historical")
                if combined_hist.empty:
                    combined_hist = chunk_df
                else:
                    combined_hist = pd.concat([combined_hist, chunk_df], ignore_index=True)
                # Deduplicate and persist after every year — fully resumable if interrupted
                combined_hist = (
                    combined_hist
                    .drop_duplicates(subset=["date"], keep="last")
                    .sort_values("date")
                    .reset_index(drop=True)
                )
                combined_hist.to_csv(hist_path, index=False, date_format="%Y-%m-%d")
                new_hist_rows += len(chunk_df)

            if chunk_idx < len(chunks) - 1:
                inter_call_sleep()
    else:
        log.info("[%s]  archive up-to-date (last: %s)", zone_key, last_hist_dt)

    # ── 2. Forecast (ECMWF, always fresh) ────────────────────────────────────
    log.info("[%s]  forecast  past_days=7  ahead=16", zone_key)
    raw_fcst = fetch_forecast(stations, past_days=7, forecast_days=16)
    fcst_df  = aggregate_zone(raw_fcst, stations)

    fcst_rows = 0
    if not fcst_df.empty:
        fcst_df   = stamp(fcst_df, zone_key, "forecast")
        fcst_rows = len(fcst_df)
        fcst_df.to_csv(fcst_path, index=False, date_format="%Y-%m-%d")

    # ── 3. Combined: historical takes priority; forecast fills gaps & future ──
    if not combined_hist.empty and not fcst_df.empty:
        hist_dates = set(combined_hist["date"].dt.date.astype(str))
        fcst_only  = fcst_df[~fcst_df["date"].dt.date.astype(str).isin(hist_dates)]
        combined   = pd.concat([combined_hist, fcst_only], ignore_index=True)
    elif not combined_hist.empty:
        combined = combined_hist.copy()
    else:
        combined = fcst_df.copy()

    if not combined.empty:
        combined = combined.sort_values("date").reset_index(drop=True)
        combined.to_csv(comb_path, index=False, date_format="%Y-%m-%d")

    return {
        "zone":          zone_key,
        "hist_total":    len(combined_hist),
        "hist_new":      new_hist_rows,
        "fcst_rows":     fcst_rows,
        "combined_rows": len(combined),
    }


# ─── master all-zones file ────────────────────────────────────────────────────

def build_master_file(zones: list, data_dir: Path) -> None:
    parts = []
    for z in zones:
        p = data_dir / "combined" / f"{z}.csv"
        if p.exists():
            parts.append(pd.read_csv(p, parse_dates=["date"]))
    if not parts:
        log.warning("No combined files found — master file not written.")
        return

    master = pd.concat(parts, ignore_index=True).sort_values(["zone", "date"])
    out    = data_dir / "europe_all_zones.csv"
    master.to_csv(out, index=False, date_format="%Y-%m-%d")
    log.info("Master file → %s  (%s rows, %d zones)", out, f"{len(master):,}", master["zone"].nunique())


# ─── CLI ──────────────────────────────────────────────────────────────────────

def parse_args():
    p = argparse.ArgumentParser(
        description="Update European ENTSO-E weather database (Open-Meteo / ERA5 / ECMWF)",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    p.add_argument(
        "--zones", nargs="+", default=ALL_ZONES, metavar="ZONE",
        help="Zone keys to update (default: all).  E.g. DE FR IT_NORD",
    )
    p.add_argument(
        "--start-date", default=DEFAULT_HISTORICAL_START, metavar="YYYY-MM-DD",
        help=f"Historical start date for first/forced pull (default: {DEFAULT_HISTORICAL_START})",
    )
    p.add_argument(
        "--data-dir", default="data", metavar="PATH",
        help="Output directory (default: ./data)",
    )
    p.add_argument(
        "--force-reload", action="store_true",
        help="Re-download all historical data from scratch (ignores existing CSVs)",
    )
    p.add_argument(
        "--no-master", action="store_true",
        help="Skip writing the combined europe_all_zones.csv master file",
    )
    p.add_argument(
        "--list-zones", action="store_true",
        help="Print all available zone keys and exit",
    )
    p.add_argument(
        "--api-key", default=None, metavar="KEY",
        help=(
            "Open-Meteo commercial API key (removes all rate limits). "
            "Alternative: set the OPENMETEO_API_KEY environment variable. "
            "Get one at open-meteo.com ($10/month)."
        ),
    )
    p.add_argument(
        "--quiet", action="store_true",
        help="Hide per-zone progress bar",
    )
    return p.parse_args()


def main():
    args = parse_args()

    # Configure API key before any fetches
    weather_api.configure(api_key=args.api_key)

    if args.list_zones:
        print("\nAvailable zones:")
        for key, cfg in ZONES.items():
            print(f"  {key:<12}  {cfg['name']}")
        print("\nZone groups:")
        for grp, members in ZONE_GROUPS.items():
            print(f"  {grp:<15}  {', '.join(members)}")
        return

    # Validate zone keys
    bad = [z for z in args.zones if z not in ZONES]
    if bad:
        print(f"ERROR: unknown zone(s): {bad}")
        print(f"Run with --list-zones to see valid keys.")
        sys.exit(1)

    data_dir = Path(args.data_dir)
    ensure_dirs(data_dir)

    api_mode = "commercial (no rate limits)" if using_commercial() else "free tier (rate-limited)"
    print(f"\n{'='*64}")
    print(f"  European Weather Updater — {date.today().isoformat()}")
    print(f"  Zones      : {len(args.zones)}")
    print(f"  Hist start : {args.start_date}  (force={args.force_reload})")
    print(f"  API        : {api_mode}")
    print(f"  Output     : {data_dir.resolve()}")
    print(f"{'='*64}\n")

    results = []
    zones_iter = (
        tqdm(args.zones, desc="Processing zones", unit="zone")
        if not args.quiet
        else args.zones
    )

    for zone_key in zones_iter:
        if not args.quiet and hasattr(zones_iter, "set_description"):
            zones_iter.set_description(f"Zone {zone_key:<10}")
        try:
            result = update_zone(zone_key, data_dir, args.start_date, args.force_reload)
            results.append(result)
        except Exception as exc:
            log.error("[%s]  FAILED: %s", zone_key, exc, exc_info=True)
            results.append({"zone": zone_key, "error": str(exc)})

    # Master file
    if not args.no_master:
        good_zones = [r["zone"] for r in results if "error" not in r]
        build_master_file(good_zones, data_dir)

    # Summary table
    print(f"\n{'='*72}")
    print(f"  {'Zone':<12}  {'Zone Name':<30}  {'Hist Total':>10}  {'New':>6}  {'Fcst':>6}  {'Combined':>9}")
    print(f"  {'-'*12}  {'-'*30}  {'-'*10}  {'-'*6}  {'-'*6}  {'-'*9}")
    for r in results:
        if "error" in r:
            print(f"  {r['zone']:<12}  ERROR: {r['error']}")
        else:
            name = ZONES[r["zone"]]["name"][:30]
            print(
                f"  {r['zone']:<12}  {name:<30}  "
                f"{r['hist_total']:>10,}  {r['hist_new']:>6,}  "
                f"{r['fcst_rows']:>6,}  {r['combined_rows']:>9,}"
            )
    print(f"{'='*72}\n")

    errors = [r for r in results if "error" in r]
    if errors:
        print(f"WARNING: {len(errors)} zone(s) failed.  Check logs above.")
        sys.exit(1)
    else:
        print(f"Done.  All {len(results)} zones updated successfully.")


if __name__ == "__main__":
    main()
